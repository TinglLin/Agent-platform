# 后端环境配置模板 — 复制为 backend/.env 后填写（不提交 Git）

# development | testing | production
APP_ENV=development

# Flask
DEBUG=true
HOST=0.0.0.0
PORT=5000

# SQLite 业务库（默认 backend/data/zhihui.db）
DATABASE_URL=sqlite:///data/zhihui.db

# LangGraph Checkpointer（P2；默认 backend/data/checkpoints.db）
CHECKPOINT_DB_PATH=data/checkpoints.db

# DeepSeek LLM（替换为你的 API Key）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
LLM_MODEL=deepseek-chat
LLM_BASE_URL=https://api.deepseek.com/v1
